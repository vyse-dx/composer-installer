{
    "name": "vyse/installer",
    "description": "Install Vyse components on composer install",
    "type": "composer-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Andy Fletcher"
        }
    ],
    "require": {
        "composer-plugin-api": "^2.0",
        "php": "^8.5"
    },
    "require-dev": {
        "vyse/toolchain": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Vyse\\Installer\\": "src/"
        }
    },
    "extra": {
        "class": "Vyse\\Installer\\Plugin"
    }
}