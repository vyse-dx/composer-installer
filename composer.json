{
    "name": "vyse/installer",
    "description": "Install Vyse components on composer install",
    "type": "composer-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Andy Fletcher"
        }
    ],
    "require": {
        "composer-plugin-api": "^2.0",
        "php": "^8.5"
    },
    "require-dev": {
        "vyse/toolchain": "^1.0",
        "composer/composer": "^2.9"
    },
    "autoload": {
        "psr-4": {
            "Vyse\\Installer\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        },
        "class": "Vyse\\Installer\\Plugin"
    },
    "config": {
        "allow-plugins": {
            "vyse/installer": true
        }
    },
    "scripts": {
        "vyse:install": "Vyse\\Installer\\Plugin::install"
    }
}